<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>FF14AccessibilityInstaller</AssemblyName>
    <!-- Eigene Installer-Version. Wird im Fenster angezeigt und gegen ein
         etwaiges Installer-Release-Asset im ff14-accessibility-Repo verglichen
         (nur Hinweistext, kein Selbst-Update - siehe InstallerService). -->
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <!-- Barrierefreiheit: WinForms-GUI. Standardcontrols (Label, TextBox, Button)
         setzen automatisch die klassischen Win32/UIA-Properties, NVDA/JAWS lesen
         sie ohne Zusatzaufwand vor. Status-Updates gehen zusaetzlich in ein
         fokussierbares, mehrzeiliges Log-Textfeld; wichtige Meldungen zusaetzlich
         per MessageBox (Standard-Win32-Dialog, wird automatisch vorgelesen). -->
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Self-contained Single-File, damit Nutzer KEIN .NET installieren muessen:
         dotnet publish -c Release -r win-x64 erzeugt eine einzelne EXE. -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <!-- Newtonsoft mit denselben Semantiken, die Dalamud fuer dalamudConfig.json
         nutzt ($type / TypeNameHandling). JObject bewahrt Property-Reihenfolge und
         die $type-Felder beim Round-Trip - System.Text.Json wuerde die Struktur
         gefaehrden. Fuer die reinen GitHub-/puni.sh-JSON-Antworten (ohne $type)
         wird dagegen System.Text.Json.Nodes verwendet (siehe InstallerService). -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
